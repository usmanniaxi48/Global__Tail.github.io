<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Global Tail</title>
    <style>
        * {
            box-sizing: border-box;
            scroll-behavior: smooth;
        }

        body {
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        header {
            position: fixed;
            top: 0;
            width: 100%;
            background-color: #222;
            color: #fff;
            padding: 15px 0;
            z-index: 999;
            text-align: center;
        }

        nav a {
            color: #fff;
            margin: 0 15px;
            text-decoration: none;
            font-weight: bold;
        }

        nav a:hover {
            color: #ffcc00;
        }

        section {
            padding: 100px 20px 50px;
            text-align: center;
        }

        h2 {
            color: #333;
            margin-bottom: 20px;
        }

        .locations {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 20px;
        }

        .card {
            width: 300px;
            background: #fff;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s ease;
        }

        .card:hover {
            transform: scale(1.05);
        }

        .card img {
            width: 100%;
            border-radius: 10px 10px 0 0;
        }

        .card h3 {
            padding: 15px 0;
            margin: 0;
            background: #f4f4f4;
            border-radius: 0 0 10px 10px;
        }

        .form-container {
            max-width: 400px;
            margin: auto;
            background: #f9f9f9;
            padding: 25px;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        input {
            width: 100%;
            padding: 12px;
            margin: 10px 0;
            border: 1px solid #ccc;
            border-radius: 5px;
        }

        button {
            width: 100%;
            padding: 12px;
            background: #222;
            color: white;
            border: none;
            border-radius: 5px;
            font-size: 16px;
            cursor: pointer;
        }

        button:hover {
            background: #444;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .locations {
                flex-direction: column;
                align-items: center;
            }

            .card {
                width: 90%;
            }

            nav a {
                display: inline-block;
                margin: 8px;
            }
        }
    </style>
</head>
<body>

    <header>
        <h1>Global Tail</h1>
        <nav>
            <a href="#home">Home</a>
            <a href="#locations">Locations</a>
            <a href="#register">Register</a>
        </nav>
    </header>

    <section id="home">
        <h2>Welcome to Global Tail</h2>
        <p>Your one-stop travel booking site.</p>
    </section>

    <section id="locations">
        <h2>Top Travel Locations</h2>
        <div class="locations">
            <div class="card"><img src="https://via.placeholder.com/300x200" alt="Paris"><h3>Paris</h3></div>
            <div class="card"><img src="https://via.placeholder.com/300x200" alt="Dubai"><h3>Dubai</h3></div>
            <div class="card"><img src="https://via.placeholder.com/300x200" alt="Istanbul"><h3>Istanbul</h3></div>
            <div class="card"><img src="https://via.placeholder.com/300x200" alt="New York"><h3>New York</h3></div>
            <div class="card"><img src="https://via.placeholder.com/300x200" alt="Tokyo"><h3>Tokyo</h3></div>
            <div class="card"><img src="https://via.placeholder.com/300x200" alt="London"><h3>London</h3></div>
            <div class="card"><img src="https://via.placeholder.com/300x200" alt="Sydney"><h3>Sydney</h3></div>
            <div class="card"><img src="https://via.placeholder.com/300x200" alt="Rome"><h3>Rome</h3></div>
        </div>
    </section>

    <section id="register">
        <h2>Register with Us</h2>
        <div class="form-container">
            <form id="registrationForm">
                <input type="text" id="fullName" placeholder="Full Name" required>
                <input type="email" id="email" placeholder="Email" required>
                <input type="text" id="destination" placeholder="Destination" required>
                <button type="submit">Submit</button>
            </form>
        </div>
    </section>

    <script>
        document.querySelectorAll('nav a').forEach(link => {
            link.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                target.scrollIntoView({ behavior: 'smooth' });
            });
        });

        document.getElementById('registrationForm').addEventListener('submit', function (e) {
            e.preventDefault();
            const name = document.getElementById('fullName').value.trim();
            const email = document.getElementById('email').value.trim();
            const destination = document.getElementById('destination').value.trim();

            if (!name || !email || !destination) {
                alert("Please fill in all fields.");
            } else {
                alert("Registration successful!");
                this.reset();
            }
        });
    </script>
</body>
</html>
